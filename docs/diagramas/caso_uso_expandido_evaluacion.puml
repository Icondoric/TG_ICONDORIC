@startuml Caso_de_Uso_Expandido_Evaluacion_de_Perfiles

' ============================================================
'  DIAGRAMA DE CASO DE USO EXPANDIDO
'  Módulo: Evaluación de Perfiles (Sprint 5)
'  Sistema: TG ICONDORIC - EMI
' ============================================================

skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam defaultFontSize 12
skinparam packageStyle rectangle
skinparam actorStyle awesome

skinparam usecase {
    BackgroundColor<<principal>> #E8EAF6
    BorderColor<<principal>> #3949AB
    BackgroundColor<<extension>> #FFF3E0
    BorderColor<<extension>> #F57C00
    BackgroundColor<<inclusion>> #E8F5E9
    BorderColor<<inclusion>> #388E3C
}

' ── Actores ──────────────────────────────────────────────
actor "Estudiante /\nTitulado" as Candidato #6A1B9A
actor "Administrador /\nOperador" as Admin #1565C0
actor "Sistema ML\n(TF-IDF + Coseno)" as SistemaML #00695C
actor "Gemini API\n(Extractor CV)" as Gemini #E65100
actor "Base de Datos\n(Supabase)" as BD #37474F

' ── Paquete del Sistema ─────────────────────────────────
rectangle "Sistema de Evaluación de Perfiles" as Sistema {

    ' ── CU Principales ──────────────────────────────────
    usecase "CU-01: Explorar Ofertas\nLaborales Disponibles" as CU01 <<principal>>
    usecase "CU-02: Postularse a\nOferta Laboral" as CU02 <<principal>>
    usecase "CU-03: Consultar Historial\nde Postulaciones" as CU03 <<principal>>
    usecase "CU-04: Evaluar Candidatos\npor Oferta" as CU04 <<principal>>
    usecase "CU-05: Generar Informe\nPDF de Evaluación" as CU05 <<principal>>

    ' ── CU de Inclusión ─────────────────────────────────
    usecase "CU-06: Verificar\nElegibilidad del\nUsuario" as CU06 <<inclusion>>
    usecase "CU-07: Extraer Perfil\nEstructurado del CV" as CU07 <<inclusion>>
    usecase "CU-08: Calcular Índice\nde Correspondencia\n(Match Score)" as CU08 <<inclusion>>
    usecase "CU-09: Clasificar\nCandidato\n(APTO/CONSIDERADO/\nNO_APTO)" as CU09 <<inclusion>>
    usecase "CU-10: Obtener\nConfiguración de\nPerfil Institucional" as CU10 <<inclusion>>

    ' ── CU de Extensión ─────────────────────────────────
    usecase "CU-11: Filtrar Ofertas\npor Tipo/Estado" as CU11 <<extension>>
    usecase "CU-12: Ver Desglose\nDetallado de Scores" as CU12 <<extension>>
    usecase "CU-13: Ajustar Top N\nde Candidatos" as CU13 <<extension>>
    usecase "CU-14: Ver Perfil\nCompleto del\nCandidato" as CU14 <<extension>>
}

' ── Relaciones Actor-CU ─────────────────────────────────
Candidato --> CU01
Candidato --> CU02
Candidato --> CU03

Admin --> CU04
Admin --> CU05
Admin --> CU01

' ── Relaciones de Inclusión ─────────────────────────────
CU01 ..> CU06 : <<include>>
CU02 ..> CU06 : <<include>>
CU02 ..> CU07 : <<include>>
CU02 ..> CU08 : <<include>>
CU02 ..> CU09 : <<include>>
CU02 ..> CU10 : <<include>>
CU03 ..> CU06 : <<include>>
CU04 ..> CU08 : <<include>>
CU05 ..> CU04 : <<include>>

' ── Relaciones de Extensión ─────────────────────────────
CU01 <.. CU11 : <<extend>>
CU02 <.. CU12 : <<extend>>
CU03 <.. CU12 : <<extend>>
CU04 <.. CU13 : <<extend>>
CU04 <.. CU14 : <<extend>>
CU04 <.. CU11 : <<extend>>

' ── Relaciones con Sistemas Externos ────────────────────
SistemaML --> CU08
Gemini --> CU07
BD --> CU06
BD --> CU10

' ── Notas ───────────────────────────────────────────────
note right of CU08
  **Modelo ML:**
  TF-IDF + Similitud Coseno
  Evalúa 5 dimensiones:
  • Hard Skills Score
  • Soft Skills Score
  • Education Score
  • Experience Score
  • Languages Score
end note

note right of CU09
  **Umbrales de Clasificación:**
  • APTO ≥ 70%
  • CONSIDERADO 40% - 69%
  • NO_APTO < 40%
end note

note bottom of CU01
  **Filtrado por Rol:**
  • Estudiante → solo Pasantías
  • Titulado → solo Empleos
  • Admin/Operador → Todas
end note

note right of CU05
  **Contenido del PDF:**
  • Portada institucional
  • Resumen ejecutivo
  • Detalle de convocatoria
  • Ranking de candidatos
  • Justificación por dimensión
end note

' ============================================================
'  SECCIÓN: CASOS DE USO EXPANDIDOS (Narrativa)
' ============================================================

note as N1
  **═══════════════════════════════════════════════**
  **CU-02: Postularse a Oferta Laboral (EXPANDIDO)**
  **═══════════════════════════════════════════════**

  **Actor Principal:** Estudiante / Titulado
  **Actores Secundarios:** Sistema ML, Gemini API, BD
  **Precondiciones:**
    1. El usuario tiene sesión activa
    2. El usuario tiene un CV cargado y procesado
    3. Existen ofertas laborales activas

  **Flujo Principal:**
    1. El usuario accede a "Correspondencia entre Perfiles"
    2. El sistema verifica la elegibilidad (CV, perfil completo)
    3. El sistema lista las ofertas disponibles según el rol
    4. El usuario selecciona una oferta y presiona "Postularme"
    5. El sistema obtiene el perfil extraído del CV (Gemini)
    6. El sistema carga la config del perfil institucional
    7. El modelo ML calcula el match_score (TF-IDF + Coseno)
    8. El sistema clasifica: APTO / CONSIDERADO / NO_APTO
    9. El sistema guarda la postulación en la BD (upsert)
    10. El sistema muestra el resultado con scores detallados

  **Flujos Alternativos:**
    3a. No hay ofertas → Mensaje "No hay ofertas disponibles"
    4a. Ya postuló → El sistema reactualiza la evaluación
    5a. CV no procesado → Error de elegibilidad
    7a. Sin perfil institucional → Se crea perfil genérico

  **Postcondiciones:**
    • Postulación registrada con match_score y clasificación
    • El usuario puede ver el desglose de scores por dimensión
    • La postulación aparece en el Historial
end note

note as N2
  **═══════════════════════════════════════════════════**
  **CU-04: Evaluar Candidatos por Oferta (EXPANDIDO)**
  **═══════════════════════════════════════════════════**

  **Actor Principal:** Administrador / Operador
  **Actores Secundarios:** Sistema ML, BD
  **Precondiciones:**
    1. Existen ofertas con postulaciones registradas
    2. El admin tiene sesión activa con rol autorizado

  **Flujo Principal:**
    1. El admin accede a "Evaluación de Candidatos"
    2. El sistema carga la lista de ofertas con stats
    3. El admin filtra por tipo/estado/búsqueda
    4. El admin selecciona una oferta
    5. El sistema obtiene el ranking de Top N candidatos
    6. El sistema muestra candidatos ordenados por score
    7. El admin expande un candidato para ver justificación
    8. El admin puede generar informe PDF

  **Flujos Alternativos:**
    2a. No hay ofertas → Mensaje vacío
    5a. No hay postulaciones → "Sin postulaciones aún"
    8a. Error al generar PDF → Mensaje de error en consola

  **Postcondiciones:**
    • El admin tiene visibilidad del ranking de candidatos
    • Informe PDF descargado (si lo solicitó)
end note

@enduml
