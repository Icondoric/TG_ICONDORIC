        <!-- Salida 3: Contribuciones -->
        <mxCell id="out3" value="&lt;b style='font-size:13px;color:#2e7d32'&gt;feature_contributions&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Para cada una de las 18 features:&lt;br&gt;&lt;b&gt;contribución = coeficiente × valor_feature&lt;/b&gt;&lt;br&gt;Muestra cuánto aporta (o resta) cada&lt;br&gt;dimensión a la predicción final&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2e7d32;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1025" y="370" width="350" height="95" as="geometry" />
        </mxCell>

