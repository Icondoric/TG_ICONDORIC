        <mxCell id="out4" value="&lt;b style='font-size:13px;color:#2e7d32'&gt;top_strengths&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Las &lt;b&gt;3 features&lt;/b&gt; con mayor contribución positiva&lt;br&gt;Formato: [(nombre_feature, valor_contribución), ...]&lt;br&gt;&lt;br&gt;&lt;i&gt;Ejemplo:&lt;/i&gt;&lt;br&gt;[(&quot;interaction_hard&quot;, 0.052),&lt;br&gt; (&quot;hard_skills_score&quot;, 0.041),&lt;br&gt; (&quot;inst_weight_hard&quot;, 0.018)]&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2e7d32;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
